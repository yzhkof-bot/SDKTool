{
  "name": "kingsdk-monorepo",
  "version": "0.1.0",
  "description": "King SDK developer toolkit monorepo - core analysis engine, viewer, HTTP server, CLI.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsup && node scripts/buildViewerTemplate.mjs",
    "build:viewer": "node scripts/buildViewerTemplate.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx packages/cli/src/index.ts",
    "clean": "rimraf dist packages/*/dist packages/viewer/templates",
    "wb": "node scripts/restart-workbench.mjs",
    "wb:nobuild": "node scripts/restart-workbench.mjs --no-build",
    "wb:dev": "node scripts/restart-workbench.mjs --dev",
    "wb:stop": "node scripts/restart-workbench.mjs --kill-only"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/yauzl": "^2.10.3",
    "happy-dom": "^20.9.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
